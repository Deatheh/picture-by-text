API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8080

USER_SERVICE_HOST=user-service
USER_SERVICE_PORT=50051
USER_SERVICE_URL=${USER_SERVICE_HOST}:${USER_SERVICE_PORT}

PICTURE_SERVICE_HOST=picture-service
PICTURE_SERVICE_PORT=50052
PICTURE_SERVICE_URL=${PICTURE_SERVICE_HOST}:${PICTURE_SERVICE_PORT}

STORAGE_SERVICE_HOST=storage-service
STORAGE_SERVICE_PORT=50053
STORAGE_SERVICE_URL=${STORAGE_SERVICE_HOST}:${STORAGE_SERVICE_PORT}

EXPORT_SERVICE_HOST=export-service
EXPORT_SERVICE_PORT=50054
EXPORT_SERVICE_URL=${EXPORT_SERVICE_HOST}:${EXPORT_SERVICE_PORT}

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=microservices

DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=${POSTGRES_SSL_MODE}

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false
MINIO_BUCKET_IMAGES=images
MINIO_BUCKET_EXPORTS=exports
MINIO_EXTERNAL_ENDPOINT=localhost:9000

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

REDIS_SESSION_DB=1
REDIS_CACHE_DB=2
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
SESSION_TTL=86400

JWT_SECRET=secret-jwt-key
JWT_ACCESS_TTL=900      
JWT_REFRESH_TTL=604800  


